MASSFLOW = MASSFLOW VISITED = 1 \ \ COMMENTS COMMENTS = ( ";" ) \ ? SETUP 
GLOBAL ? \ "IN-UNITS" INSET = SET1 \ ? SETUP DIAGNOSTICS ? ? SETUP 
